@using Permit_to_work.ViewModel
@model IEnumerable<PermitDashboardVM>
@{
    ViewData["Title"] = "PermitDashboard";
}
<!DOCTYPE html>
<html>
<head>
    <title>Simple Modal Popup</title>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        body {
            font-family: Arial;
        }

        /* Overlay background */
        #modalOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
        }

        /* Modal box */
        #modalBox {
            background: white;
            width: 350px;
            padding: 20px;
            border-radius: 8px;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* .closeBtn {
            float: right;
            cursor: pointer;
            color: red;
            font-weight: bold;
        } */

        button {
            padding: 8px 15px;
            cursor: pointer;
        }
    </style>
</head>
<body>

   @*  <h2>Permit To Work</h2> *@
    <div class="row" style="padding:1%;">
        <div class="col-md-4">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search Permit Type, Unit, Location, Status...">
        </div>
    </div>
      <div class="container mt-1">
        <div class="card shadow-lg">
          
            <div class="card-header bg-dark text-white text-center fs-4">
                 Dashboard
            </div>
           
            <div class="card-body">
                <table class="table table-bordered align-middle text-center" id="permitTable">
                    <thead class="table-secondary">
                        <tr>
                            <th>Permit Type</th>
                            <th>Unit</th>
                            <th>Location</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr data-type="@item.PermitType" data-dashboardid="@item.PermitDashBoardId">
                                <td class="fw-bold">@item.PermitType</td>
                                <td>@item.Unit</td>
                                <td>@item.Location</td>
                                <td>@item.StartDate.ToString("dd-MM-yyyy")</td>
                                <td>@item.EndDate.ToString("dd-MM-yyyy")</td>
                                <td>
                                    <span class="badge bg-success">@item.Status</span>
                                </td>
                                <td>
                                 
                                    <a class="btn btn-sm btn-primary"
                                       href="/@item.PermitType.Replace(" ", "")/Edit/@item.PermitDashBoardId">
                                        ✏ Edit
                                    </a>

                                    <a class="btn btn-sm btn-warning openModal">
                                        ⏱ Extend
                                    </a>

                                    <a class="btn btn-sm btn-danger"
                                       href="/Dashboard/Delete?type=@item.PermitType&id=@item.PermitDashBoardId"
                                       onclick="return confirm('Delete this permit?');">
                                        🗑 Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row">
                <div class="col-lg-12" style="text-align:right;padding-right:2%;padding-bottom:1%;">
                <button class="btn btn-success" style="width:20%;">Add New Permit</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
  
    <div id="modalOverlay">
        <div class="modal-dialog">
            <form method="post" action="/Dashboard/ExtendPermit">
                <div class="modal-content">
                    <div class="modal-header bg-warning">
                        <h5>Extend Permit</h5>
                    </div>
                    <input type="hidden" id="hdnpermittype" />
                    <input type="hidden" id="permitid" />
                    <div class="modal-body">
                        <input type="hidden" id="PermitId" name="PermitId" />
                        <label>New End Date</label>
                        <input type="date" class="form-control" name="NewEndDate" required />
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-success">Extend</button>
                        <button class="btn btn-warning closeBtn">Close</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <script>
        $(document).ready(function () {

            // Open modal
            // $("#openModal").click(function () {
            //     debugger;
            //     $("#modalOverlay").fadeIn();
            // });

                   

            // Close modal
            $(".closeBtn").click(function () {
                $("#modalOverlay").fadeOut();
            });

            // Close when clicking outside
            $("#modalOverlay").click(function (e) {
                if ($(e.target).is("#modalOverlay")) {
                    $("#modalOverlay").fadeOut();
                }
            });

        });

         $(document).on("click", ".openModal", function () {
             var permitType = $(this).closest("tr").data("type");
             var dashboardId = $(this).closest("tr").data("dashboardid");
             $("#hdnpermittype").val(permitType);
             $("#permitid").val(dashboardId);
            $("#modalOverlay").fadeIn();
        });
    </script>

</body>
</html>
