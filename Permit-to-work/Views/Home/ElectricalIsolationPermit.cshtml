@model ElectricalIsolationPermit
@{
    ViewData["Title"] = "ElectricalIsolationPermit";
   
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Electrical Isolation Permit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #fff9e6; /* very light yellow for page background */
            padding: 20px;
        }

        .card {
            border: 2px solid #f7c948; /* golden yellow border */
            border-radius: 10px;
            margin-bottom: 20px;
            background: #fffbe0; /* soft creamy yellow */
            padding: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .section-title {
            background: #f7c948; /* golden yellow */
            font-weight: bold;
            padding: 6px 10px;
            margin-bottom: 10px;
            border: 1px solid #e6b800; /* darker yellow border */
            color: #3e2723; /* dark brown text for contrast */
            border-radius: 4px;
        }

        label {
            font-weight: 600;
            color: #3e2723; /* dark brown */
        }

        .form-check-label {
            margin-left: 4px;
            color: #3e2723;
        }

        .row > .col {
            margin-bottom: 10px;
        }

        .others-input {
            margin-top: 5px;
        }

        .border-section {
            border: 1px solid #f7c948; /* golden yellow border */
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            background: #fffde6; /* very soft yellow */
        }

        .btn-success {
            background-color: #f7b500; /* bright yellow button */
            border-color: #e6a300;
            color: #ffffff;
        }

            .btn-success:hover {
                background-color: #e6a300;
                border-color: #cc8f00;
            }

    </style>
</head>

<body>
    <form method="post" class="container">

        <div class="card">
            <div class="card-header text-center fw-bold">
                ELECTRICAL (ISOLATION) PERMIT
            </div>

            <!-- BASIC DETAILS -->
            <section class="mt-3 border-section">
                <div class="section-title">Basic Details</div>
                <div class="row">
                    <div class="col-md-3">
                        <label>Unit</label>
                        @Html.TextBoxFor(m => m.Unit, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Date</label>
                        @Html.TextBoxFor(m => m.PermitDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Location</label>
                        @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Number of Workmen</label>
                        @Html.TextBoxFor(m => m.NumberOfWorkmen, new { @class = "form-control" })
                    </div>
                </div>
            </section>

            <!-- DATE & TIME -->
            <section class="mt-3 border-section">
                <div class="section-title">Date & Time</div>
                <div class="row">
                    <div class="col-md-3">
                        <label>Starting From Date</label>
                        @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Starting From Time</label>
                        @Html.TextBoxFor(m => m.StartTime, new { type = "time", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Expected Completion Date</label>
                        @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Expected Completion Time</label>
                        @Html.TextBoxFor(m => m.EndTime, new { type = "time", @class = "form-control" })
                    </div>
                </div>
            </section>

            <!-- ENERGY STATUS -->
            <section class="mt-3 border-section">
                <div class="section-title">Energy Status</div>
                <div class="row">
                    <div class="col">
                        @Html.CheckBoxFor(m => m.EnergizedEquipment) <label>Energized Lines/Equipment</label>
                    </div>
                    <div class="col">
                        @Html.CheckBoxFor(m => m.DeEnergizedEquipment) <label>De-Energized Lines/Equipment</label>
                    </div>
                </div>
            </section>

            <!-- WORK DESCRIPTION & TOOLS -->
            <section class="mt-3 border-section">
                <div class="section-title">Work Description</div>
                @Html.TextAreaFor(m => m.WorkDescription, 3, 100, new { @class = "form-control" })

                <div class="section-title mt-3">Tools/Equipment to be used</div>
                @Html.TextAreaFor(m => m.ToolsEquipment, 2, 100, new { @class = "form-control" })
            </section>

            <!-- RISK IDENTIFICATION -->
            <section class="mt-3 border-section">
                <div class="section-title">Identify Risks Associated with Work</div>
                <div class="row">
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskElectrocution) <label>Electrocution</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskArcFlash) <label>Arc Flash</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskFlyingParticles) <label>Flying Particles</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskNoise) <label>Noise</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskFallingObjects) <label>Falling Objects</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskProtrudingParts) <label>Protruding Objects/Parts</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskTripping) <label>Tripping / Slipping</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskElectricShock) <label>Electric Shock</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskFire) <label>Fire</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskManualHandling) <label>Manual Handling</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskElectricBurn) <label>Electric Burn</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.RiskOverheadLines) <label>Near Overhead Lines</label></div>
                    <div class="col-md-6">
                        <label>Other (Specify)</label>
                        <input type="text" name="OtherRisk" class="form-control others-input" />
                    </div>
                </div>
            </section>

            <!-- DOCUMENTS ATTACH -->
            <section class="mt-3 border-section">
                <div class="section-title">Documents to Attach</div>
                <div class="row">
                    <div class="col-md-2">@Html.CheckBoxFor(m => m.JSA) <label>JSA</label></div>
                    <div class="col-md-2">@Html.CheckBoxFor(m => m.RiskAssessment) <label>Risk Assessment</label></div>
                    <div class="col-md-4">
                        <label>Other (Specify)</label>
                        <input type="text" name="OtherDocument" class="form-control others-input" />
                    </div>
                </div>
            </section>

            <!-- PRECAUTION -->
            <section class="mt-3 border-section">
                <div class="section-title">Precaution required to complete the work safely</div>
                <div class="form-check form-check-inline">@Html.RadioButtonFor(m => m.Precaution, "Yes", new { @class = "form-check-input" }) <label class="form-check-label">Yes</label></div>
                <div class="form-check form-check-inline">@Html.RadioButtonFor(m => m.Precaution, "No", new { @class = "form-check-input" }) <label class="form-check-label">No</label></div>
                <div class="form-check form-check-inline">@Html.RadioButtonFor(m => m.Precaution, "N/A", new { @class = "form-check-input" }) <label class="form-check-label">N/A</label></div>


                <div class="container mt-2">

                    <!-- Safe Distance Label -->
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label><strong>Safe Distance Maintained?</strong></label>
                        </div>
                    </div>

                    <!-- Safe Distance Yes/No -->
                    <div class="row mb-3">
                        <div class="col-md-2">
                            <div class="form-check">
                                @Html.RadioButtonFor(m => m.SafeDistance, "Yes", new { @class = "form-check-input", id = "safeYes" })
                                <label class="form-check-label" for="safeYes">Yes</label>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <div class="form-check">
                                @Html.RadioButtonFor(m => m.SafeDistance, "No", new { @class = "form-check-input", id = "safeNo" })
                                <label class="form-check-label" for="safeNo">No</label>
                            </div>
                        </div>
                    </div>

                    <!-- Voltage & Distance -->
                    <div class="row mb-3">
                        <div class="col-md-3">-
                            <label>Voltage</label>
                            @Html.TextBoxFor(m => m.Voltage, new { @class = "form-control" })
                        </div>

                        <div class="col-md-3">
                            <label>Distance</label>
                            @Html.TextBoxFor(m => m.Distance, new { @class = "form-control" })
                        </div>
                    </div>

                    <!-- Confined Space Label -->
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <label><strong>Confined Space Required?</strong></label>
                        </div>
                    </div>

                    <!-- Confined Yes/No -->
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-check">
                                @Html.RadioButtonFor(m => m.ConfinedSpace, "Yes", new { @class = "form-check-input", id = "confinedYes" })
                                <label class="form-check-label" for="confinedYes">Yes</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-check">
                                @Html.RadioButtonFor(m => m.ConfinedSpace, "No", new { @class = "form-check-input", id = "confinedNo" })
                                <label class="form-check-label" for="confinedNo">No</label>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Electrical Isolation (LOTO) -->
                <div class="row mt-3">
                    <div class="col-md-12">
                        <label>
                            <strong>
                                Have all possible sources of electrical power been isolated, locked and properly tagged (LOTO)?
                            </strong>
                        </label>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-2">
                        <div class="form-check">
                            @Html.RadioButtonFor(m => m.ElectricalIsolation, "Yes",
                                     new { @class = "form-check-input", id = "lotoYes" })
                            <label class="form-check-label" for="lotoYes">Yes</label>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <div class="form-check">
                            @Html.RadioButtonFor(m => m.ElectricalIsolation, "No",
                                     new { @class = "form-check-input", id = "lotoNo" })
                            <label class="form-check-label" for="lotoNo">No</label>
                        </div>
                    </div>
                </div>



            </section>

            <!-- LOTO -->
            <section class="mt-3 border-section">
                <div class="section-title">LOTO / Isolation Procedure</div>
                <div class="row">
                    <div class="col-md-3">
                        @Html.CheckBoxFor(m => m.SwitchOut)
                        <label>Switch Out</label>
                    </div>

                    <div class="col-md-3">
                        @Html.CheckBoxFor(m => m.LockoutTagout)
                        <label>Lockout/Tagout</label>
                    </div>

                    <div class="col-md-3">
                        <label>No. of Locks</label>
                        @Html.TextBoxFor(m => m.NumberOfLocks, new { @class = "form-control" })
                    </div>

                    <div class="col-md-6">
                        @Html.CheckBoxFor(m => m.TestConfirmed)
                        <label>Confirmed by Testing (De-energized)</label>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6">@Html.CheckBoxFor(m => m.ToolsTested) <label>Tools/Devices Tested and Adjusted</label></div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-6">
                        <label>Other (Specify)</label>
                        <input type="text" name="OtherLOTO" class="form-control others-input" />
                    </div>
                </div>
            </section>

            <!-- INSURANCE -->
            <section class="mt-3 border-section">
                <div class="section-title">Insurance / WC / ESI Copy available for Workmen</div>
                <div class="row">
                    <div class="col-md-2">@Html.CheckBoxFor(m => m.WC) <label>WC</label></div>
                    <div class="col-md-2">@Html.CheckBoxFor(m => m.ESI) <label>ESI</label></div>
                    <div class="col-md-4">
                        <label>Other (Specify)</label>
                        <input type="text" name="OtherInsurance" class="form-control others-input" />
                    </div>
                </div>
            </section>

            <!-- INSPECTION -->
            <section class="mt-3 border-section">
                <div class="section-title">Inspection by Issuer / Receiver</div>

                <div class="row">

                    <!-- Fire Extinguisher -->
                    <div class="col-md-3">
                        @Html.CheckBoxFor(m => m.FireExtinguisher)
                        <label>Fire Extinguisher</label>
                    </div>

                    <div class="col-md-3">
                        <label>Type</label>
                        @Html.TextBoxFor(m => m.FireExtinguisherType,
                                 new { @class = "form-control form-control-sm" })
                    </div>

                    <div class="col-md-3">
                        <label>Quantity</label>
                        @Html.TextBoxFor(m => m.FireExtinguisherQuantity,
                                 new { @class = "form-control form-control-sm" })
                    </div>

                    <div class="col-md-3">
                        <label>Size</label>
                        @Html.TextBoxFor(m => m.FireExtinguisherSize,
                                 new { @class = "form-control form-control-sm" })
                    </div>

                    <!-- Other Inspection Items -->
                    <div class="col-md-3 mt-3">
                        @Html.CheckBoxFor(m => m.AccessRoute)
                        <label>Access / Escape Route</label>
                    </div>

                    <div class="col-md-3 mt-3">
                        @Html.CheckBoxFor(m => m.DangerSign)
                        <label>Danger / Warning Sign</label>
                    </div>

                    <div class="col-md-3 mt-3">
                        @Html.CheckBoxFor(m => m.Lighting)
                        <label>Lighting</label>
                    </div>

                    <div class="col-md-3 mt-3">
                        @Html.CheckBoxFor(m => m.SafetyBarriers)
                        <label>Safety Barriers</label>
                    </div>

                </div>
            </section>


            <!-- PPE -->
            <section class="mt-3 border-section">
                <div class="section-title">PPE Required for Activity</div>
                <div class="row">
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEHelmet) <label>Helmet</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEShoes) <label>Safety Shoes</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEElectricalGloves) <label>Electrical Gloves</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEHalfMask) <label>Half Mask</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPESafetyGoggles) <label>Safety Goggles</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEReflectiveVest) <label>Reflective Vest</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEDustMask) <label>Dust Mask</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEFaceShield) <label>Face Shield</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPEArcFlash) <label>Arc Flash PPE</label></div>
                    <div class="col-md-3">@Html.CheckBoxFor(m => m.PPESafetyEar) <label>Safety Ear Plugs / Muff</label></div>
                    <div class="col-md-3">
                        <label>Other (Specify)</label>
                        <input type="text" name="OtherPPE" class="form-control others-input" />
                    </div>
                </div>
            </section>

            <!-- AUTHORIZATION -->
            <section class="mt-3 border-section">
                <div class="section-title">Issue & Acceptance</div>
                <div class="row">
                    <div class="col-md-6">
                        <label>Permit Receiver Name</label>
                        @Html.TextBoxFor(m => m.ReceiverName, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6">
                        <label>Receiver Signature / Date</label>
                        @Html.TextBoxFor(m => m.ReceiverSignatureDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-6">
                        <label>Permit Issuer Name</label>
                        @Html.TextBoxFor(m => m.IssuerName, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6">
                        <label>Issuer Signature / Date</label>
                        @Html.TextBoxFor(m => m.IssuerSignatureDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                </div>
            </section>

            <!-- SUSPENSION -->
            <section class="mt-3 border-section">
                <div class="section-title">Suspension</div>
                <label>This permit is suspended, area/equipment is not safe to use.</label>
                <div class="row mt-2">
                    <div class="col-md-6">
                        <label>Name</label>
                        @Html.TextBoxFor(m => m.SuspensionName, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6">
                        <label>Signature / Date</label>
                        @Html.TextBoxFor(m => m.SuspensionSignatureDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                </div>
            </section>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success px-5">Submit Permit</button>
            </div>
        </div>
    </form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
