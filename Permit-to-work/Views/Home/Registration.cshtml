@model Permit_to_work.Models.Login

@{
    ViewData["Title"] = "Registration";
}

<div class="container mt-5" style="max-width: 30%; margin-top: 10px;">
        
    <div class="card shadow-1g p-4" style="border-radius:12px; ">
        <h2 class="text-center mb-4" style="color: #222831;">
            REGISTRATION
        </h2>

        <form asp-action="Save" asp-controller="Home" method="post" autocomplete="off">
            @Html.ValidationSummary(true, "", new{ @class = "text-danger"})
            <div>
                <label>Employee Name</label>
                
                <input type="text" name="EmployeeName" class="form-control" asp-for="EmployeeName" placeholder="Enter your Name" required />
            </div>

            <div>
                <label>Username</label>
                <input type="text" id="Username" name="Username" asp-for="Username" class="form-control" autocomplete="new-username" placeholder="Enter your ID" required />
                
                <span
                    id="empError" style="color: red; display:none;">
                    Invalid ID. Enter only numbers.<br /><br />
                </span>
            </div>

            <div>
                <label>Password</label>
                <input type="password" id="password" name="Password" asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Enter password" required />
                </div>
            
            <div class="radio-group">
                <label>Admin Rights</label>
                <br />

                <input type="radio" asp-for="AdminRights"  id="yes" value="true" />
                <label for="yes">Yes</label>

                <input type="radio" asp-for="AdminRights"  id="no" value="fasle" />
                <label for="no">No</label>

                <span asp-validation-for="AdminRights" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                Save
            </button>

            <button type="reset" class="btn btn-secondary ms-3">
                Clear
            </button>
        </form>
    </div>
</div>

<script>

    document.getElementById("EmployeeID").addEventListener("input", function () {
        debugger;
        var value = this.value.trim();
        var error = document.getElementById("empError");

        if (value === "")
        {
            error.style.display = "none";
        }  
        
        else if (/^\d*$/.test(value)) 
        {
            error.style.display = "none";
        }

        else {
            error.style.display = "block";
        }
    });

    function togglePassword()
    {
        var pwd = document.getElementById("password");

        if (pwd.type === "password")
        {
            pwd.type = "text";
        }

        else {
            pwd.type = "password";
        }
    }

</script>
