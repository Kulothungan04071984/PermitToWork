@model WorkAtHeightPermit

<form method="post" class="container my-4 px-2">

    <link rel="stylesheet" href="~/css/Height.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <div class="card shadow">
        <section class="card permit-card">

            <div class="section-title">
            <div class="card-header text-center fw-bold">
                WORK AT HEIGHT PERMIT
            </div>
            </div>
            </section>


            <div class="card-body">

                <!-- BASIC DETAILS -->
                <div class="section-title">Basic Details</div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label>
                            Unit <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.Unit, new { @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>
                            Contractor <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.ContractorTeam, new { @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>
                            Location <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
                    </div>
                    
                    <div class="col-md-3">
                        <label>
                            No. of Workmen <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.NoOfWorkmen, new { @class = "form-control" })
                    </div>
                </div>

                <!-- DATE & TIME -->
                <div class="section-title mt-4">Date & Time</div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label>
                            Starting Date <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>
                            Starting time <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.StartTime, new { type = "time", @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>
                            Expected Date <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>
                            Expected time <span class="required-star">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.EndTime, new { type = "time", @class = "form-control" })
                    </div>
                </div>

                <!-- WORK TYPE -->
                
                <section class="card permit-card">
                    <fieldset>
                        <div class="section-title">
                            Work Type <span class="required-star">*</span>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="Scaffolding" />
                                    <label class="form-check-label">Scaffolding</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="Ladder" />
                                    <label class="form-check-label">Ladder</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="AerialLift" />
                                    <label class="form-check-label">Aerial Lift</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="RoofWork" />
                                    <label class="form-check-label">Roof Work</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label>Others</label>
                                <input type="text" name="OtherWorkType" class="form-control" />
                            </div>
                        </div>
                    </fieldset>
                </section>


                <!-- DESCRIPTION -->
                <div class="section-title mt-4">Work Description</div>
                @Html.TextAreaFor(m => m.WorkDescription, 3, 100, new { @class = "form-control" })

                <!-- TOOLS -->
                <div class="section-title mt-4">Tools / Equipment</div>
                @Html.TextAreaFor(m => m.ToolsEquipment, 2, 100, new { @class = "form-control" })

                <!-- RISK IDENTIFICATION -->


                <section class="card permit-card">
                    <fieldset>
                        <div class="section-title">
                            Identify Risk Associated with Work at Height <span class="required-star">*</span>
                        </div> 

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="FallFromHeight" />
                                    <label class="form-check-label">Fall from Height</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="AdverseWeather" />
                                    <label class="form-check-label">Adverse Weather</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="FlyingParticles" />
                                    <label class="form-check-label">Flying Particles</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="MovingVehicle/Equipment" />
                                    <label class="form-check-label">Moving Vehicle/Equipment</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="FallingDebris/Objects" />
                                    <label class="form-check-label">Falling Debris/Objects</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="ProtrudingObjects/parts" />
                                    <label class="form-check-label">Protruding Objects/parts</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="Tripping/Slipping" />
                                    <label class="form-check-label">Tripping / Slipping</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="FaultyEquipment/Material" />
                                    <label class="form-check-label">Faulty Equipment/Material</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="FragileSurface/Roof" />
                                    <label class="form-check-label"> Fragile Surface/Roof</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="WorkUnderBelow" />
                                    <label class="form-check-label">Work Under Below</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="NearOverheadLines" />
                                    <label class="form-check-label">Near Overhead Lines</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="NearEnergizedEquipment" />
                                    <label class="form-check-label">Near Energized Equipment</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label>Others</label>
                                <input type="text" name="OtherRiskIdentification" class="form-control" />
                            </div>
                        </div>
                    </fieldset>
                </section>

                <!-- DOCUMENTS -->

                <section class="card permit-card">
                    <fieldset>
                        <div class="section-title">
                            Documents to Attach
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="JSA" />
                                    <label class="form-check-label">JSA</label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="RiskAssessment" />
                                    <label class="form-check-label">Risk Assessment</label>
                                </div>
                            </div>                           

                            <div class="col-md-4">
                                <label>Others</label>
                                <input type="text" name="OtherDocuments" class="form-control" />
                            </div>
                        </div>
                    </fieldset>
                </section>




        <!-- SECTION: PRECAUTION --> 
        <section class="card permit-card">
            <div class="section-title">Precaution measures required to complete the work safely</div>

            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.Precaution, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>

                <div class="form-check">
                    @Html.RadioButtonFor(m => m.Precaution, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>

                <div class="form-check">
                    @Html.RadioButtonFor(m => m.Precaution, "N/A", new { @class = "form-check-input" })
                    <label class="form-check-label">N/A</label>
                </div>
            </div>
        </section>


        <!-- RISK CONTROL -->
        <section class="card permit-card">
            <div class="section-title">
                Have the risk control/s been implemented 
            </div>

            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.Riskcontrol, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>

                <div class="form-check">
                    @Html.RadioButtonFor(m => m.Riskcontrol, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>
            </div>


            <!-- SECTION: PRECAUTION -->

            <div class="section-title">Fall Protection</div>

            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.CheckBoxFor(m => m.GuardRailsSystem, new { @class = "form-check-input" })
                    <label class="form-check-label">Guard Rails System</label>
                </div>

                <div class="form-check">
                    @Html.CheckBoxFor(m => m.SafetyNet, new { @class = "form-check-input" })
                    <label class="form-check-label">Safety Net</label>
                </div>

                <div class="form-check">
                    @Html.CheckBoxFor(m => m.ToeBoard, new { @class = "form-check-input" })
                    <label class="form-check-label">Toe Board</label>
                </div>
            </div>


            <div class="section-title">Fall Restraint</div>

            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.CheckBoxFor(m => m.LifeLine, new { @class = "form-check-input" })
                    <label class="form-check-label">Life Line</label>
                </div>

                <div class="form-check">
                    @Html.CheckBoxFor(m => m.RetractableHarness, new { @class = "form-check-input" })
                    <label class="form-check-label">Retractable Harness</label>
                </div>
            </div>


            <div class="section-title"> Fall Arrest</div>


            <div class="form-check">
                <div class="col-md-4">
                    @Html.CheckBoxFor(m => m.HarnessShockAbsorber,new { @class = "form-check-input"}) 
                    <label class="form-check-label">Harness with Shock Absorber </label>
                </div>
            </div>

            <div class="form-check">
                <div class="col-md-4">
                    @Html.CheckBoxFor(m => m.HarnessShockAbsorber, new { @class = "form-check-input" })
                    <label class="form-check-label">Double Hook </label>
                </div>

            </div>

            <div class="section-title">Have proper access/egress been provided?</div>
            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.AccessProvided, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.AccessProvided, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>
            </div>

            <div class="section-title">Is wind speed greater than 32 km/h?</div>
            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.WindGreater32, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.WindGreater32, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>
            </div>

            <div class="section-title">Are floor openings covered?</div>
            <div class="d-flex gap-3">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.FloorOpeningsCovered, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.FloorOpeningsCovered, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>
            </div>


            <div class="section-title">Scaffold inspected by Certified Person?</div>
            <div class="d-flex gap-3 align-items-center">
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.ScaffoldCertified, "Yes", new { @class = "form-check-input" })
                    <label class="form-check-label">Yes</label>
                </div>
                <div class="form-check">
                    @Html.RadioButtonFor(m => m.ScaffoldCertified, "No", new { @class = "form-check-input" })
                    <label class="form-check-label">No</label>
                </div>
                <div class="form-check d-flex align-items-center">
                    <label class="form-check-label me-2 mb-0">Others</label>
                    <input type="text" name="OtherRisk" class="form-control" style="width: 300px;" />
                </div>
            </div>



        </section>


        <!-- INSPECTION -->
        <section class="card permit-card">
            <fieldset>
                <div class="section-title">
                    Inspection by Issuer / Receiver
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="DangerWarningSign" />
                            <label class="form-check-label">Danger/Warning Sign</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="ScaffoldTagSystem" />
                            <label class="form-check-label">Scaffold Tag System</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="Lighting" />
                            <label class="form-check-label">Lighting</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="SafetyBarriers" />
                            <label class="form-check-label">Safety Barriers</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="BuddySystem" />
                            <label class="form-check-label">Buddy System</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="Rescue" />
                            <label class="form-check-label">Rescue</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="MaterialBasket" />
                            <label class="form-check-label">Material Basket</label>
                        </div>
                    </div>


                    <div class="col-md-4">
                        <label>Others</label>
                        <input type="text" name="OtherInspection" class="form-control" />
                    </div>
                </div>
            </fieldset>


            <!-- PPE -->

                <fieldset>
                    <div class="section-title mt-4">
                        PPE Required
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="HelmetwithChinstrap" />
                                <label class="form-check-label"> Helmet with Chin strap</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="Safetygoggles" />
                            <label class="form-check-label">Safety goggles</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="SafetyShoes" />
                            <label class="form-check-label">Safety Shoes</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="SafetyGloves" />
                            <label class="form-check-label">Safety Gloves</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="SafetyEarPlugs/muff" />
                            <label class="form-check-label">Safety Ear Plugs/muff</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="ReflectiveVest" />
                            <label class="form-check-label">Reflective Vest</label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="DustMask" />
                            <label class="form-check-label">Dust Mask</label>
                            </div>
                        </div>

                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="Safetyclothes" />
                            <label class="form-check-label">Safety clothes</label>
                        </div>
                    </div>

                        <div class="col-md-4">
                            <label>Others</label>
                            <input type="text" name="OtherPPE" class="form-control" />
                        </div>
                    </div>
                </fieldset>



            <!-- INSURANCE COPY -->
            <div class="section-title">Insurance copy available for workmen:</div>
            <div class="row align-items-center g-3">
                    <div class="col-auto">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.WC, new { @class = "form-check-input", id = "wc" })
                            <label class="form-check-label">WC</label>
                        </div>

                        <div id="wcUpload" style="display:none; margin-top:5px;">
                            <input type="file" name="WCFile" id="wcFile"
                                   class="form-control form-control-sm"
                                   style="background: #f4f7fb; border:1px solid #000;" />
                        </div>
                    </div>

                    <div class="col-auto">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.ESI, new { @class = "form-check-input", id = "esi" })
                            <label class="form-check-label">ESI</label>
                        </div>

                        <div id="esiUpload" style="display:none; margin-top:5px;">
                            <input type="file" name="ESIFile" id="esiFile"
                                   class="form-control form-control-sm"
                                   style="background: #f4f7fb; border:1px solid #000;" />
                        </div>
                    </div>

                <div class="col-auto">
                    <label>Others</label>
                    <input type="text" name="OtherInsurance" class="form-control" style="display:inline-block; width:auto;" />
                </div>
            </div>


            <!-- AUTHORIZATION -->
            <div class="section-title mt-4">Authorization</div>
            <div class="row g-3">
                <div class="col-md-6"> <label>Permit Receiver name</label>@Html.TextBoxFor(m => m.ReceiverName, new { @class = "form-control" })</div>
                <div class="col-md-3"> <label>Receiver Date</label>@Html.TextBoxFor(m => m.ReceiverDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })</div>

            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label>Permit Issuer name</label>@Html.TextBoxFor(m => m.IssuerName, new { @class = "form-control" })
                </div>
                <div class="col-md-3">
                    <label>Issuer Date</label>@Html.TextBoxFor(m => m.IssuerDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                </div>

                </div>


                <!-- SUSPENSION -->

            <div class="section-title">Suspension</div>
            <label>This permit is suspended, area/equipment is not safe to use.</label>
            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label>Name</label>
                    @Html.TextBoxFor(m => m.SuspensionName, new { @class = "form-control" })
                </div>

                <div class="col-md-6">
                    <label>Date</label>
                    <div class="col-md-6">@Html.TextBoxFor(m => m.SuspensionSignatureDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })</div>

                    </div>
                </div>


                <!-- Approver Details -->

                
                <section class="permit-section">
                <div class="section-title">Approver Details</div>
                    
                    <div class="row">
                        <div class="col-lg-3">
                            <label>
                                Approver One Email <span style="color:red">*</span>
                            </label>

                            @Html.TextBoxFor(m => m.ApproverOne, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.ApproverOne, "", new { @class = "text-danger" })

                        </div>
                        <div class="col-lg-3">
                            <label>Approver Two Email</label>
                            @Html.TextBoxFor(m => m.ApproverTwo, new { @class = "form-control" })
                        </div>
                        <div class="col-lg-3">
                            <label>Approver Three Email</label>
                            @Html.TextBoxFor(m => m.ApproverThree, new { @class = "form-control" })
                        </div>
                        <div class="col-lg-3">
                            <label>Approver Four Email</label>
                            @Html.TextBoxFor(m => m.ApproverFour, new { @class = "form-control" })
                        </div>
                    </div>
                </section>


            <!-- Approver Details -->

            <div class="section-title">Approver Details</div>

            <div class="col-lg-3">
                <label>Approver One Email</label>
                @Html.TextBoxFor(m => m.ApproverOne, new { @class = "form-control" })
            </div>
            <div class="col-lg-3">
                <label>Approver Two Email</label>
                @Html.TextBoxFor(m => m.ApproverTwo, new { @class = "form-control" })
            </div>
            <div class="col-lg-3">
                <label>Approver Three Email</label>
                @Html.TextBoxFor(m => m.ApproverThree, new { @class = "form-control" })
            </div>
            <div class="col-lg-3">
                <label>Approver Four Email</label>
                @Html.TextBoxFor(m => m.ApproverFour, new { @class = "form-control" })
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success px-5">Submit Permit</button>
            </div>
        </section>
    </div>
    </div>



</form>



<script>
