<table class="table table-bordered">
    <thead class="table-danger">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Site inspection and planning</td>
            <td>Slips, trips, unclear routing path</td>
            <td>Conduct site survey, identify route, remove obstacles</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Material handling (cables, trays, tools)</td>
            <td>Manual handling injury, strain</td>
            <td>Use proper lifting techniques, team lifting for heavy cables, use trolleys</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Accessing work area (ladder/scaffold)</td>
            <td>Fall from height</td>
            <td>Use certified ladders/scaffolds, ensure proper positioning, use PPE (helmet, safety shoes)</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Marking cable route</td>
            <td>Exposure to sharp edges, poor visibility</td>
            <td>Use proper marking tools, ensure adequate lighting</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Drilling and fixing supports/trays</td>
            <td>Dust inhalation, noise, electric shock</td>
            <td>Use dust mask, ear plugs, check for live wires before drilling, use insulated tools</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Cable pulling and routing</td>
            <td>Hand injury, cable snap, strain</td>
            <td>Use gloves, proper pulling tools, avoid over tension, maintain communication</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Working near live electrical panels</td>
            <td>Electric shock, arc flash</td>
            <td>Ensure power isolation (LOTO), use insulated PPE, maintain safe distance</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Cutting and termination of cables</td>
            <td>Cuts, burns, incorrect termination</td>
            <td>Use proper cutting tools, wear gloves, follow SOP</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Housekeeping during work</td>
            <td>Slips, trips due to scattered materials</td>
            <td>Maintain clean work area, dispose scrap properly</td>
        </tr>
        <tr>
            <td>10</td>
            <td>Testing and commissioning</td>
            <td>Electric shock, short circuit</td>
            <td>Use proper testing equipment, ensure connections are correct, authorized personnel only</td>
        </tr>
        <tr>
            <td>11</td>
            <td>Completion and inspection</td>
            <td>Missed defects, unsafe installation</td>
            <td>Final inspection, ensure proper fixing and labeling</td>
        </tr>
    </tbody>
</table>