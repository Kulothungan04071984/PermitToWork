<table class="table table-bordered" style="background-color:yellow">
   
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Pre-use inspection of machine</td>
            <td>Damaged cable, loose parts, blade damage</td>
            <td>Inspect machine, ensure proper guarding, check cable condition</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Wearing PPE</td>
            <td>Exposure to sparks, cuts, noise</td>
            <td>Safety gloves, goggles/face shield, ear plugs, safety shoes</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Marking and positioning material</td>
            <td>Hand injury, improper cutting</td>
            <td>Trained operators</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Handling hot material after cutting</td>
            <td>Burns</td>
            <td>Allow cooling time, use gloves or tools to handle</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Switching off machine</td>
            <td>Accidental contact with moving blade</td>
            <td>Switch off and wait until blade stops completely</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Cleaning and housekeeping</td>
            <td>Cuts from sharp edges, slips</td>
            <td>Use brush (not hands), clean area, remove scrap properly</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Storage of machine</td>
            <td>Damage, unauthorized use</td>
            <td>Store in designated place, disconnect power</td>
        </tr>
    </tbody>
</table>