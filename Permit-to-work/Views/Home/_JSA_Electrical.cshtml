<table class="table table-bordered text-center">
   
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Isolation of power supply</td>
            <td>Electric shock, arc flash</td>
            <td>Switch off power, apply Lockout Tagout (LOTO), verify isolation with tester</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Use of tools & equipment</td>
            <td>Faulty tools causing shock or injury</td>
            <td>Use insulated tools, check tools condition before use</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Cable handling and wiring</td>
            <td>Cuts, electric shock, short circuit</td>
            <td>Use proper cable stripping tools, ensure cables are not damaged</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Earthing and grounding</td>
            <td>Electric shock due to leakage</td>
            <td>Ensure proper grounding, test earthing before energizing</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Re-energizing the system</td>
            <td>Unexpected power supply, shock</td>
            <td>Ensure all persons are clear, remove LOTO, inform team before energizing</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Housekeeping after work</td>
            <td>Trips, leftover hazards</td>
            <td>Remove tools, waste materials, ensure clean and safe area</td>
        </tr>
    </tbody>
</table>