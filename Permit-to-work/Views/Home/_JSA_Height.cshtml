<table class="table table-bordered jsa-table">
    <thead class="jsa-header">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Work planning & site inspection</td>
            <td>Inadequate hazard identification</td>
            <td>Conduct risk assessment, obtain work permit</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Mobilization of tools & equipment</td>
            <td>Falling objects, improper tools</td>
            <td>Use tool lanyards, inspect tools before use</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Erection of ladder/scaffold</td>
            <td>Collapse, instability</td>
            <td>Use certified scaffold, ensure firm base, proper erection</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Accessing height (ladder/scaffold)</td>
            <td>Slipping, falling</td>
            <td>Maintain 3-point contact, use anti-slip ladder, secure ladder</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Working at height</td>
            <td>Fall from height</td>
            <td>Use full body harness with double lanyard, anchor to lifeline</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Movement at height</td>
            <td>Loss of balance</td>
            <td>Avoid overreaching, maintain proper footing</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Material handling at height</td>
            <td>Dropping materials</td>
            <td>Use rope & pulley, avoid manual lifting, barricade area below</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Electrical work at height (if any)</td>
            <td>Electric shock</td>
            <td>Ensure isolation, use insulated tools, check cables</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Completion of work</td>
            <td>Leaving tools/materials</td>
            <td>Clear area, safely lower tools, inspect site</td>
        </tr>
        <tr>
            <td>10</td>
            <td>Dismantling scaffold/ladder</td>
            <td>Falling parts</td>
            <td>Follow proper dismantling procedure, use PPE</td>
        </tr>
        <tr>
            <td>11</td>
            <td>Emergency situation</td>
            <td>Injury/fall</td>
            <td>Ensure rescue plan, first aid availability, trained personnel</td>
        </tr>
    </tbody>
</table>