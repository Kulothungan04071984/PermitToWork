<table class="table table-bordered">
    <thead class="table-danger">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Inspection of lifting equipment (crane, sling, hooks)</td>
            <td>Equipment failure, load drop</td>
            <td>Check certification, inspect for damage, ensure SWL marked, no defective tools</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Selection of proper lifting tools & tackles</td>
            <td>Overloading, improper lifting</td>
            <td>Use correct capacity slings, shackles, and hooks as per load weight</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Barricading the work area</td>
            <td>Unauthorized entry, struck-by hazard</td>
            <td>Barricade area, display warning signs, restrict entry</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Positioning of crane / lifting equipment</td>
            <td>Crane instability, overturning</td>
            <td>Ensure level ground, use outriggers, maintain safe distance from edges</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Rigging of load</td>
            <td>Load slipping, imbalance</td>
            <td>Proper sling angle, secure knots, use tag lines, ensure balanced load</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Trial lifting (test lift)</td>
            <td>Load shift, unexpected failure</td>
            <td>Lift slightly and check balance & stability before full lifting</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Actual lifting operation</td>
            <td>Falling load, collision, struck-by</td>
            <td>Follow signals, maintain communication, no one under suspended load</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Guiding the load (using tag lines)</td>
            <td>Hand injury, caught-in hazard</td>
            <td>Use tag lines, maintain safe distance, wear gloves</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Lowering and placement of load</td>
            <td>Crushing, pinch points</td>
            <td>Ensure clear area, slow lowering, proper alignment</td>
        </tr>
        <tr>
            <td>10</td>
            <td>Removal of lifting tools</td>
            <td>Dropped objects, improper handling</td>
            <td>Carefully remove slings/hooks, store properly after use</td>
        </tr>
        <tr>
            <td>11</td>
            <td>Post-work inspection & housekeeping</td>
            <td>Trip hazards, equipment damage</td>
            <td>Inspect tools, clear area, proper storage</td>
        </tr>
    </tbody>
</table>