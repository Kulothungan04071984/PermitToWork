<table class="table table-bordered">
    <thead class="table-danger">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Machine shutdown</td>
            <td>Unexpected machine movement, electrical shock</td>
            <td>Follow proper shutdown procedure, inform operators</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Isolation of energy sources (LOTO)</td>
            <td>Electrical shock, stored energy release</td>
            <td>Implement Lockout-Tagout (LOTO), verify isolation</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Area barricading & signage</td>
            <td>Unauthorized entry, accidental exposure</td>
            <td>Place barricades and warning signs</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Removal of machine guards/parts</td>
            <td>Sharp edges, falling parts, hand injury</td>
            <td>Use proper tools, wear gloves, ensure stable handling</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Inspection of machine components</td>
            <td>Exposure to oil, grease, dust</td>
            <td>Wear PPE (gloves, goggles), maintain cleanliness</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Electrical maintenance work</td>
            <td>Electric shock, short circuit</td>
            <td>Use insulated tools, ensure power isolation, test before touch</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Mechanical repair/replacement</td>
            <td>Pinch points, crush injury</td>
            <td>Use proper lifting tools, avoid hand placement in danger zones</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Lubrication and cleaning</td>
            <td>Slips, chemical exposure</td>
            <td>Use proper lubricants, clean spills immediately, wear PPE</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Reassembly of machine parts</td>
            <td>Improper fitting, loose components</td>
            <td>Follow SOP, tighten all fasteners, double-check assembly</td>
        </tr>
        <tr>
            <td>10</td>
            <td>Removal of tools and housekeeping</td>
            <td>Trip hazards, leftover tools</td>
            <td>Clear tools, clean area, dispose waste properly</td>
        </tr>
        <tr>
            <td>11</td>
            <td>Trial run / testing</td>
            <td>Abnormal operation, noise, vibration</td>
            <td>Conduct trial run under supervision, monitor parameters</td>
        </tr>
        <tr>
            <td>12</td>
            <td>Handover to production</td>
            <td>Miscommunication</td>
            <td>Inform operator, update records, close permit</td>
        </tr>
    </tbody>
</table>