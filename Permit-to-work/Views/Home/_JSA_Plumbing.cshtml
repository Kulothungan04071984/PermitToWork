<table class="table table-bordered text-center">
    <thead style="background-color: yellow; color: black;">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Mobilization of tools and materials</td>
            <td>Manual handling injury, slips/trips</td>
            <td>Use proper lifting techniques, wear safety shoes, keep access clear</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Inspection of work area</td>
            <td>Presence of hidden utilities, unsafe conditions</td>
            <td>Conduct site inspection, identify underground/overhead services, barricade area</td>
        </tr>
        <tr>
            <td>3</td>
            <td>Cutting of pipes</td>
            <td>Cuts, flying particles</td>
            <td>Use hand gloves, safety goggles, proper cutting tools</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Threading / Grooving</td>
            <td>Finger injury, entanglement</td>
            <td>Use machine guards, avoid loose clothing, trained operator only</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Lifting and positioning pipes</td>
            <td>Strains, crush injury</td>
            <td>Use lifting aids, team lifting, proper posture</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Pipe joining (welding/solvent cementing)</td>
            <td>Fumes, fire hazard, chemical exposure</td>
            <td>Use PPE (mask, gloves), ensure ventilation, fire extinguisher available</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Working at height (overhead piping)</td>
            <td>Fall from height</td>
            <td>Use scaffolding, safety harness, proper access ladder</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Housekeeping and debris removal</td>
            <td>Slips, cuts from sharp waste</td>
            <td>Dispose waste properly, maintain clean workspace</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Demobilization</td>
            <td>Tool-related injury, leftover hazards</td>
            <td>Collect tools, clear site, final inspection</td>
        </tr>
