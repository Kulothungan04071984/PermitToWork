<table class="table table-bordered text-center">
    <thead style="background-color:yellow; font-weight:bold;">
        <tr>
            <th>Sl No</th>
            <th>Activities (Sequential Task)</th>
            <th>Hazard</th>
            <th>Required Control</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>1</td>
            <td>Inspection of welding machine & cables</td>
            <td>Electric shock, damaged equipment</td>
            <td>Check cables, electrode holder, earthing; ensure no cuts/damage</td>
        </tr>
        <tr>
            <td>2</td>
            <td>Workplace setup</td>
            <td>Fire hazard, poor ventilation</td>
            <td>Remove flammable materials, ensure proper ventilation, barricade area</td>
        </tr>
        <tr>
            <td>3</td>
            <td>PPE usage</td>
            <td>Eye injury, burns, inhalation</td>
            <td>Wear welding helmet, gloves, apron, safety shoes, face shield</td>
        </tr>
        <tr>
            <td>4</td>
            <td>Arc welding operation</td>
            <td>Arc flash, UV radiation, burns</td>
            <td>Use proper welding screen, maintain safe distance, avoid direct exposure</td>
        </tr>
        <tr>
            <td>5</td>
            <td>Fume generation</td>
            <td>Respiratory issues</td>
            <td>Ensure local exhaust ventilation, use mask/respirator if needed</td>
        </tr>
        <tr>
            <td>6</td>
            <td>Sparks & slag generation</td>
            <td>Fire, burns</td>
            <td>Keep fire extinguisher nearby, use fire blanket/screens</td>
        </tr>
        <tr>
            <td>7</td>
            <td>Working at height (if applicable)</td>
            <td>Fall hazard</td>
            <td>Use proper scaffolding, safety harness</td>
        </tr>
        <tr>
            <td>8</td>
            <td>Completion of welding</td>
            <td>Residual heat, fire risk</td>
            <td>Allow cooling, inspect area for sparks/fire</td>
        </tr>
        <tr>
            <td>9</td>
            <td>Housekeeping & shutdown</td>
            <td>Slips, leftover hazards</td>
            <td>Switch off power, clean slag/waste, store equipment properly</td>
        </tr>
    </tbody>
</table>