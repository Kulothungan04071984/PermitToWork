@model ColdWorkPermitVM
@{
    ViewData["Title"] = "Permit To Work";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cold Work Permit</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="~/css/permit.css" rel="stylesheet" />
</head>

<body>
    <div class="hero">
        <!-- STICKY HEADER -->
        <header class="sticky-header shadow">
            <h4 class="m-0">COLD WORK PERMIT</h4>
        </header>

@* *@
        <form method="post" class="container permit-container">
@* >>>>>>> other/master *@

            <!-- SECTION: BASIC DETAILS -->
            <section class="permit-section">
                <h5>Basic Details</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label>Unit</label>
                        @Html.TextBoxFor(m => m.Unit, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4">
                        <label>Contractor / Internal Team</label>
                        @Html.TextBoxFor(m => m.ContractorTeam, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4">
                        <label>Location</label>
                        @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4">
                        <label>No. of Workmen</label>
                        @Html.TextBoxFor(m => m.NoOfWorkmen, new { @class = "form-control" })
                    </div>
                </div>
            </section>

            <section class="card permit-card">
                <div class="row g-3">

                    <div class="col-md-3">
                        <label>Starting From Date</label>
                        @Html.TextBoxFor(m => m.StartDate,
                                 "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Starting From Time</label>
                        @Html.TextBoxFor(m => m.StartTime,
                                 new { type = "time", @class = "form-control" })
                    </div>

                    <!-- Expected Completion Date & Time -->
                    <div class="col-md-3">
                        <label>Expected Completion Date</label>
                        @Html.TextBoxFor(m => m.EndDate,
                                 "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Expected Completion Time</label>
                        @Html.TextBoxFor(m => m.EndTime,
                                 new { type = "time", @class = "form-control" })
                    </div>
            </section>

            <!-- SECTION: WORK -->
            <section class="permit-section">
                <h5>Work Description</h5>
                @Html.TextAreaFor(m => m.WorkDescription, 3, 100, new { @class = "form-control" })
            </section>

            <!-- SECTION: TOOLS -->
            <section class="permit-section">
                <h5>Tools / Equipment</h5>
                @Html.TextAreaFor(m => m.ToolsEquipment, 2, 100, new { @class = "form-control" })
            </section>

            <!-- SECTION: RISKS -->
            <section class="permit-section">
                <h5>Risk Identification</h5>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFallHeight) Fall from Height
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskWeather) Adverse Weather
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFlying) Flying Particles
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Equipment) Moving Vehicle/ Equipment
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Falling) Falling Debris/ Objects
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Protruding) Protruding objects, parts
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Tripping) Tripping / Slipping
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Faulty) Faulty Tool/ Material
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Noise) Noise
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Heat) Heat
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Vibration) Vibration
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Illumination) Poor Illumination
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        Other
                        <input type="text" class="form-control" />
                    </div>
                </div>
            </section>

            <!-- SECTION: DOCUMENT -->
            <section class="permit-section">
                <h5>The following document must be attached with this permit</h5>
                <div class="row g-3 align-items-end">

                    <div class="col-md-4">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.AttachJSA, new { @class = "form-check-input", id = "jsa" })
                            <label class="form-check-label" for="jsa">JSA</label>
                        </div>

                        <div id="jsaList" style="display:none; max-height:150px; overflow-y:auto; border:1px solid #ccc; padding:8px;">

                            <div><input type="checkbox" id="jsa_cutting"> Cutting machine</div>
                            <div><input type="checkbox" id="jsa_excavation"> Excavation</div>
                            <div><input type="checkbox" id="jsa_welding"> Welding</div>
                            <div><input type="checkbox" id="jsa_electrical"> Electrical Work</div>
                            <div><input type="checkbox" id="jsa_Height"> Height Work</div>
                            <div><input type="checkbox" id="jsa_plumbing"> plumbing</div>
                            <div><input type="checkbox" id="jsa_cable"> cable Routing</div>
                            <div><input type="checkbox" id="jsa_Lifting"> Lifting</div>
                            <div><input type="checkbox" id="jsa_Machine"> Machine maintenance</div>





                        </div>
                    </div>
                    <div class="col-md-4">
                        Other
                        <input type="text" class="form-control" />
                    </div>
                </div>
            </section>
            <!-- SECTION: PRECAUTION -->
            <section class="permit-section">
                <h5>Precaution required to complete the work safely</h5>

                <label class="form-check form-check-inline  ">
                    <input class=" form-check-input" style="border-radius:15% !important" type="radio" name="precaution" value="yes">
                    Yes
                </label>

                <label class="form-check form-check-inline ">
                    <input class=" form-check-input" style="border-radius:15% !important" type="radio" name="precaution" value="no">
                    No
                </label>
                <label class="form-check form-check-inline ">
                    <input class=" form-check-input" style="border-radius:15% !important" type="radio" name="precaution" value="N/A">
                    N/A
                </label>

            </section>



            <!-- SECTION: TOOLS ADJUSTED -->
            <section class="permit-section">
                <h5>Have tools and devices to be used been tested and adjusted?</h5>

                <div class="form-check form-check-inline">
                    <input class="form-check-input" style="border-radius:15% !important" type="radio" name="toolsTested" value="yes">
                    Yes</label>
                </div>

                <div class="form-check form-check-inline ms-3">
                    <input class="form-check-input" style="border-radius:15% !important" type="radio" name="toolsTested" value="no">

                    No </label>
                </div>
                <div class="form-check form-check-inline ms-3">
                    <input class="form-check-input" style="border-radius:15% !important" type="radio" name="toolsTested" value="N/A">
                    N/A </label>
                </div>
            </section>


            <!-- SECTION: HAZARDOUS -->
            <section class="permit-section hazard-section">
                <h5>Have all hazards/hazardous related to these activities identified and assessed?</h5>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFallHeight) Working at height
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskWeather) Scaffolding
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFlying) Tool & Equipment
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Equipment) Chemical
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Falling) Electrical
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Protruding) Lifting
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Tripping) Hot Surface
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Faulty) Dust
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 d-flex align-items-center mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="hazardNA" value="N/A" id="hazardNA">
                            <label class="form-check-label ms-2" for="hazardNA">N/A</label>
                        </div>
                    </div>
                </div>

            </section>



            <!-- SECTION: PERMITS ASSOCIATED -->
            <section class="permit-section permit-associated-section">
                <h5>Are permits associated require for this activity? if yes, mentioned below</h5>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFallHeight) Hot Work
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskWeather) Working At Height
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.RiskFlying) Excavation
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Equipment) Electrical
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBoxFor(m => m.Falling) Confined Space to Entry
                    </div>
                    <div class="col-md-4 ">
                        Other (specify):
                        <input id="txtother" type="text" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 d-flex align-items-center mt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="permitassociated" value="N/A" id="permitNA">
                            <label class="form-check-label ms-2" for="permitNA">N/A</label>
                        </div>
                    </div>
                </div>


            </section>

            <!-- SECTION: INSURANCE -->
            <section class="permit-section">
                <div class="section-title">Insurance copy available for workmen:</div>

                <div class="d-flex gap-3 align-items-start">
                    <!-- WC -->
                    <div class="me-3">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.WC, new { @class = "form-check-input", id = "wc" })
                            <label class="form-check-label" for="wc">WC</label>
                        </div>
                        <div id="wcUpload" style="display:none; margin-top:5px;">
                            <input type="file" name="WCFile" id="wcFile"
                                   class="form-control form-control-sm"
                                   style="background: #f4f7fb; border:1px solid #000;" />
                        </div>
                    </div>

                    <!-- ESI -->
                    <div>
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.ESI, new { @class = "form-check-input", id = "esi" })
                            <label class="form-check-label" for="esi">ESI</label>
                        </div>
                        <div id="esiUpload" style="display:none; margin-top:5px;">
                            <input type="file" name="ESIFile" id="esiFile"
                                   class="form-control form-control-sm"
                                   style="background: #f4f7fb; border:1px solid #000;" />
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: INSPECTION -->
            <section class="permit-section">
                <h5>Inspected Areas</h5>
                <div class="row g-2">
                    <div class="col-md-3"><input type="checkbox" /> Access / Egress</div>
                    <div class="col-md-3"><input type="checkbox" /> Danger / Warning Sign</div>
                    <div class="col-md-3"><input type="checkbox" /> Lighting</div>
                    <div class="col-md-3"><input type="checkbox" /> Safety Barriers</div>
                    <div class="col-md-3"><input type="checkbox" /> Hand Tools</div>
                    <div class="col-md-3">
                        Other
                        <input type="text" class="form-control" />
                    </div>

                    <div class="row">
                        <div class="col-md-4 d-flex align-items-center mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Inspected" value="N/A" id="inspectNA">
                                <label class="form-check-label ms-2" for="inspectNA">N/A</label>
                            </div>
                        </div>
                    </div>
              
            </section>

            <!-- SECTION: PPE -->
            <section class="permit-section">
                <h5>PPE Required</h5>
                <div class="row">
                    <div class="col-md-4">@Html.CheckBoxFor(m => m.PPEHelmet) Helmet</div>
                    <div class="col-md-4">@Html.CheckBoxFor(m => m.PPEShoes) Safety Shoes</div>
                    <div class="col-md-4">@Html.CheckBoxFor(m => m.PPEGloves) Safety Gloves</div>
                    <div class="col-md-4"><input type="checkbox" />  safety Goggles</div>
                    <div class="col-md-4"><input type="checkbox" />Dust Mask</div>
                    <div class="col-md-4"><input type="checkbox" /> Safety Ear Plugs/muff</div>
                    <div class="col-md-4"><input type="checkbox" /> Reflective Vest</div>
                    <div class="col-md-4"><input type="checkbox" /> Safety Harness</div>
                    <div class="col-md-3">
                        Other
                        <input type="text" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input me-2" type="radio" name="PPE" value="N/A">
                            <label class="form-check-label">N/A</label>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: AUTHORIZATION -->
            <section class="permit-section">
                <h5>Authorization</h5>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label>Permit Receiver</label>
                        @Html.TextBoxFor(m => m.ReceiverName, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3"> <label>Receiver Date</label>@Html.TextBoxFor(m => m.ReceiverDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })</div>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label>Permit Issuer</label>
                        @Html.TextBoxFor(m => m.IssuerName, new { @class = "form-control" })
                    </div>

                    <div class="col-md-3">
                        <label>Issuer Date</label>@Html.TextBoxFor(m => m.IssuerDate, "{0:yyyy-MM-dd}", new { type = "date", @class = "form-control" })
                    </div>
                </div>
            </section>

            <!-- SECTION: Suspension of permit -->
            <section class="permit-section">
                <h5>Clearance and cancellation after work or Suspension of permit</h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label>Name</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3">
                        <label>Suspension Date</label>
                        @Html.TextBoxFor(m => m.SuspensionDate,
                                 Model.SuspensionDate.HasValue ? Model.SuspensionDate.Value.ToString("yyyy-MM-dd") : "",
                                 new { type = "date", @class = "form-control" })
                    </div>

            </section>

            <!-- ACTIONS -->
            <div class="text-center my-4 no-print">
                <button type="submit" class="btn btn-success px-4">Save</button>
                <button type="button" onclick="window.print()" class="btn btn-secondary px-4">Print</button>
            </div>

        </form>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <!-- Scroll Animation -->
        <script>
            const observer = new IntersectionObserver(entries => {
                entries.forEach(e => e.isIntersecting && e.target.classList.add("show"));
            });
            document.querySelectorAll(".permit-section").forEach(s => observer.observe(s));

            document.addEventListener('DOMContentLoaded', function () {

                const naRadio = document.querySelector('input[name="permitassociated"][value="N/A"]');
                const checkboxes = document.querySelectorAll('.permit-associated-section input[type="checkbox"]');

                const otherInput = document.getElementById('txtother');

                if (naRadio) {
                    naRadio.addEventListener('change', function () {

                        if (this.checked) {

                            checkboxes.forEach(cb => {
                                cb.checked = false;
                                cb.disabled = true;
                            });

                            /
                            if (otherInput) {
                                otherInput.value = '';
                                otherInput.disabled = true;
                            }
                        } else {

                            checkboxes.forEach(cb => cb.disabled = false);
                            if (otherInput) otherInput.disabled = false;
                        }

                    });
                }

            });
        </script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {

                const wc = document.getElementById("wc");
                const esi = document.getElementById("esi");

                const wcUpload = document.getElementById("wcUpload");
                const esiUpload = document.getElementById("esiUpload");

                const wcFile = document.getElementById("wcFile");
                const esiFile = document.getElementById("esiFile");

                const wcFileName = document.getElementById("wcFileName");
                const esiFileName = document.getElementById("esiFileName");

                if (wc) {
                    wc.addEventListener("change", function () {
                        wcUpload.style.display = this.checked ? "block" : "none";
                    });
                }

                if (esi) {
                    esi.addEventListener("change", function () {
                        esiUpload.style.display = this.checked ? "block" : "none";
                    });
                }

                if (wcFile && wcFileName) {
                    wcFile.addEventListener("change", function () {
                        wcFileName.innerText = this.files.length > 0 ? this.files[0].name : "";
                    });
                }

                if (esiFile && esiFileName) {
                    esiFile.addEventListener("change", function () {
                        esiFileName.innerText = this.files.length > 0 ? this.files[0].name : "";
                    });
                }
            });
        </script>

        <script>
            document.addEventListener("DOMContentLoaded", function () {


                const jsa = document.getElementById("jsa");


                const jsaList = document.getElementById("jsaList");


                if (jsa) {
                    jsa.addEventListener("change", function () {
                        jsaList.style.display = this.checked ? "block" : "none";
                    });
                }





                const jsaCutting = document.getElementById("jsa_cutting");

                if (jsaCutting) {
                    jsaCutting.addEventListener("change", function () {
                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('cuttingModal'));
                            modal.show();
                        }
                    });
                }

                const jsaExcavation = document.getElementById("jsa_excavation");

                if (jsaExcavation) {
                    jsaExcavation.addEventListener("change", function () {
                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('excavationModal'));
                            modal.show();
                        }
                    });
                }

                const welding = document.getElementById("jsa_welding");

                if (welding) {
                    welding.addEventListener("change", function () {

                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('weldingModal'));
                            modal.show();
                        }

                    });
                }
                const jsaElectrical = document.getElementById("jsa_electrical");

                if (jsaElectrical) {
                    jsaElectrical.addEventListener("change", function () {

                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('electricalModal'));
                            modal.show();
                        }

                    });
                }
                const jsaHeight = document.getElementById("jsa_Height");

                if (jsaHeight) {
                    jsaHeight.addEventListener("change", function () {

                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('heightModal'));
                            modal.show();
                        }

                    });
                }
                const plumbing = document.getElementById("jsa_plumbing");

                if (plumbing) {
                    plumbing.addEventListener("change", function () {
                        if (this.checked) {
                            var modal = new bootstrap.Modal(document.getElementById('plumbingModal'));
                            modal.show();
                        }
                    });
                }
                const cableCheckbox = document.getElementById("jsa_cable");

                if (cableCheckbox) {
                    cableCheckbox.addEventListener("change", function () {
                        if (this.checked) {
                            let modal = new bootstrap.Modal(document.getElementById("cableModal"));
                            modal.show();
                        }
                    });
                }
                const liftingCheckbox = document.getElementById("jsa_Lifting");

                if (liftingCheckbox) {
                    liftingCheckbox.addEventListener("change", function () {
                        if (this.checked) {
                            const liftingModal = new bootstrap.Modal(document.getElementById("liftingModal"));
                            liftingModal.show();
                        }
                    });
                }
                const machineCheckbox = document.getElementById("jsa_Machine");

                if (machineCheckbox) {
                    machineCheckbox.addEventListener("change", function () {
                        if (this.checked) {
                            const modal = new bootstrap.Modal(document.getElementById("machineModal"));
                            modal.show();
                        }
                    });
                }
            });
        </script>
        <div class="modal fade" id="cuttingModal">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">JSA - Cutting</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        @await Html.PartialAsync("~/Views/Home/_JSA_Cutting.cshtml")
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-success" data-bs-dismiss="modal">OK</button>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="excavationModal">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">JSA - Excavation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        @await Html.PartialAsync("~/Views/Home/_JSA_Excavation.cshtml")
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-success" data-bs-dismiss="modal">OK</button>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="weldingModal">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">JSA - Welding</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        @await Html.PartialAsync("~/Views/Home/_JSA_Welding.cshtml")
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-success" data-bs-dismiss="modal">OK</button>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="electricalModal">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">JSA - Electrical Work</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        @await Html.PartialAsync("~/Views/Home/_JSA_Electrical.cshtml")
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-success" data-bs-dismiss="modal">OK</button>
                    </div>

                </div>
            </div>
        </div>
        <div class="modal fade" id="heightModal">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

